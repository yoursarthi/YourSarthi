# ── Server ──────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── PostgreSQL ───────────────────────────────────────────────
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=

# ── Google Gemini (chat + embeddings — used by AI Tutor and Evaluation) ────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Embedding model is fixed to text-embedding-004 (768 dims) — no config needed

# ── Uploads ──────────────────────────────────────────────────
UPLOAD_MAX_MB=50

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── JWT (if you add token-based auth later) ──────────────────
JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=7d
